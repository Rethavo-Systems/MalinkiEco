rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid));
    }

    function isAdmin() {
      return signedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        userDoc(request.auth.uid).data.role == 'ADMIN';
    }

    function isModerator() {
      return signedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        userDoc(request.auth.uid).data.role == 'MODERATOR';
    }

    function canCreateEvents() {
      return isAdmin() || isModerator();
    }

    function canWriteOwnRegistrationRequest(requestId) {
      return signedIn() &&
        request.auth.uid == requestId &&
        !exists(/databases/$(database)/documents/users/$(requestId)) &&
        request.resource.data.status in ['VERIFYING', 'VERIFIED', 'PENDING'] &&
        request.resource.data.reviewedById == '' &&
        request.resource.data.reviewedByName == '' &&
        request.resource.data.reviewReason == '';
    }

    function validNotificationJobBase() {
      return request.resource.data.status == 'PENDING' &&
        request.resource.data.title is string &&
        request.resource.data.body is string &&
        request.resource.data.category is string &&
        request.resource.data.destination in ['events', 'chat', 'owners', 'polls', 'payments', 'auth'] &&
        request.resource.data.audience in ['broadcast', 'users', 'emails', 'direct_email'] &&
        request.resource.data.attempts == 0 &&
        request.resource.data.processingWorker == '' &&
        request.resource.data.lastError == '' &&
        request.resource.data.createdAtClient is int &&
        request.resource.data.nextAttemptAtClient == request.resource.data.createdAtClient &&
        request.resource.data.sendEmail is bool &&
        request.resource.data.sendPush is bool;
    }

    function canCreateNotificationJob() {
      return signedIn() &&
        validNotificationJobBase() &&
        (
          (
            request.resource.data.audience in ['emails', 'direct_email'] &&
            request.resource.data.destination == 'auth' &&
            request.resource.data.category == 'verification' &&
            request.resource.data.sendEmail == true &&
            request.resource.data.sendPush == false
          ) ||
          (
            request.resource.data.audience in ['emails', 'direct_email'] &&
            request.resource.data.destination in ['events', 'polls', 'payments'] &&
            request.resource.data.category in ['events', 'polls', 'payments'] &&
            request.resource.data.sendEmail == true &&
            request.resource.data.sendPush == false &&
            (
              canCreateEvents() ||
              request.resource.data.category == 'polls'
            )
          ) ||
          (
            request.resource.data.audience == 'broadcast' &&
            (
              canCreateEvents() ||
              request.resource.data.category in ['chat', 'polls']
            )
          ) ||
          (
            request.resource.data.audience == 'users'
          )
        );
    }

    function validWebPushSubscription() {
      return request.resource.data.userId == request.auth.uid &&
        request.resource.data.endpoint is string &&
        request.resource.data.endpoint.size() > 0 &&
        request.resource.data.p256dhKey is string &&
        request.resource.data.p256dhKey.size() > 0 &&
        request.resource.data.authKey is string &&
        request.resource.data.authKey.size() > 0 &&
        request.resource.data.platform == 'web' &&
        request.resource.data.appMode in ['standalone', 'browser'] &&
        request.resource.data.userAgent is string &&
        request.resource.data.createdAtClient is int &&
        request.resource.data.updatedAtClient is int &&
        request.resource.data.expirationTime is int;
    }

    match /users/{userId} {
      allow read: if signedIn();

      allow create: if isAdmin() || isModerator() ||
        (signedIn() &&
         request.auth.uid == userId &&
         request.resource.data.role in ['USER', 'MODERATOR', 'ADMIN', 'TESTER']);

      allow update: if isAdmin() ||
        (isModerator() &&
         request.resource.data.diff(resource.data).changedKeys().hasOnly(['balance'])) ||
        (signedIn() &&
         request.auth.uid == userId &&
         request.resource.data.diff(resource.data).changedKeys().hasOnly(['lastChatReadAt']));

      allow delete: if isAdmin();
    }

    match /payments/{paymentId} {
      allow read: if signedIn();

      allow create: if isAdmin() || isModerator() ||
        (signedIn() && request.resource.data.userId == request.auth.uid);

      allow update, delete: if false;
    }

    match /payment_requests/{requestId} {
      allow read: if isAdmin() || isModerator() ||
        (signedIn() && resource.data.userId == request.auth.uid);

      allow create: if signedIn() &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.status == 'PENDING';

      allow update: if isAdmin() || isModerator();

      allow delete: if false;
    }

    match /registration_requests/{requestId} {
      allow read: if isAdmin() || isModerator() ||
        (signedIn() && request.auth.uid == requestId);

      allow create: if canWriteOwnRegistrationRequest(requestId);

      allow update: if isAdmin() || isModerator() ||
        canWriteOwnRegistrationRequest(requestId);

      allow delete: if false;
    }

    match /notification_jobs/{jobId} {
      allow create: if canCreateNotificationJob();
      allow read, update, delete: if false;
    }

    match /plots/{plotId} {
      allow read: if signedIn();
      allow create, update: if isAdmin() || isModerator();
      allow delete: if false;
    }

    match /app_settings/{docId} {
      allow read: if docId == 'app_gate' || signedIn();
      allow write: if isAdmin() || isModerator();
    }

    match /audit_logs/{logId} {
      allow read: if isAdmin() || isModerator();
      allow create: if isAdmin() || isModerator();
      allow update, delete: if false;
    }

    match /web_push_subscriptions/{subscriptionId} {
      allow create, update: if signedIn() && validWebPushSubscription();
      allow read: if false;
      allow delete: if signedIn() && resource.data.userId == request.auth.uid;
    }

    match /chat_messages/{messageId} {
      allow read: if signedIn();

      allow create: if signedIn() &&
        request.resource.data.senderId == request.auth.uid;

      allow update: if signedIn() && (
        (
          resource.data.senderId == request.auth.uid &&
          request.resource.data.senderId == resource.data.senderId &&
          request.resource.data.diff(resource.data).changedKeys().hasOnly([
            'text',
            'updatedAtClient',
            'senderName',
            'senderPlotName'
          ])
        ) ||
        (
          request.resource.data.senderId == resource.data.senderId &&
          request.resource.data.diff(resource.data).changedKeys().hasOnly([
            'isPinned',
            'pinnedByUserId',
            'pinnedByUserName',
            'pinnedAtClient'
          ]) &&
          (
            (
              request.resource.data.isPinned == true &&
              request.resource.data.pinnedByUserId == request.auth.uid &&
              request.resource.data.pinnedAtClient > 0
            ) ||
            (
              request.resource.data.isPinned == false &&
              request.resource.data.pinnedByUserId == '' &&
              request.resource.data.pinnedByUserName == '' &&
              request.resource.data.pinnedAtClient == 0
            )
          )
        )
      );

      allow delete: if signedIn() &&
        resource.data.senderId == request.auth.uid;
    }

    match /events/{eventId} {
      allow read: if signedIn();

      allow create: if
        (
          canCreateEvents() &&
          request.resource.data.createdById == request.auth.uid
        ) ||
        (
          signedIn() &&
          request.resource.data.createdById == request.auth.uid &&
          request.resource.data.type == 'POLL'
        );

      allow update: if
        (
          canCreateEvents() &&
          resource.data.type == 'CHARGE' &&
          request.resource.data.diff(resource.data).changedKeys().hasOnly([
            'isClosed',
            'closedById',
            'closedByName',
            'closedAtClient',
            'message'
          ])
        ) ||
        (
          signedIn() &&
          resource.data.type == 'POLL' &&
          (
            canCreateEvents() ||
            resource.data.createdById == request.auth.uid
          ) &&
          request.resource.data.diff(resource.data).changedKeys().hasOnly([
            'isClosed',
            'closedById',
            'closedByName',
            'closedAtClient',
            'message'
          ])
        ) ||
        (
          signedIn() &&
          resource.data.type == 'POLL' &&
          (resource.data.isClosed == false || resource.data.isClosed == null) &&
          !(request.auth.uid in resource.data.voterIds) &&
          request.auth.uid in request.resource.data.voterIds &&
          request.resource.data.diff(resource.data).changedKeys().hasOnly([
            'pollVotes',
            'voterIds',
            'voterChoices'
          ])
        );

      allow delete: if false;
    }
  }
}
